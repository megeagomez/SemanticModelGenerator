model Model
	culture: es-ES
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: es-ES
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["InternetSales","Customer","DimDate","Product"]

annotation PBI_ProTooling = ["DevMode","TMDLView_Desktop"]

ref table InternetSales
ref table Customer
ref table DimDate
ref table Product

ref cultureInfo es-ES

